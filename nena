<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nena Nails & Bakery</title>
<style>
/* Reset default margins */
* {
margin: 0;
padding: 0;
box-sizing: border-box;
font-family: 'Arial', sans-serif;
}

body {
background: linear-gradient(135deg, #ff1c1c, #0a0a7a); /* Ruby red to dark blue */
color: #fff;
min-height: 100vh;
display: flex;
flex-direction: column;
align-items: center;
}

header {
width: 100%;
text-align: center;
padding: 2rem 0;
background: rgba(0,0,0,0.5);
}

header h1 {
font-family: 'Press Start 2P', cursive; /* Pixel-style font */
font-size: 2.5rem;
color: #00f; /* Blue pixel color */
text-shadow: 2px 2px #000;
}

nav {
margin-top: 1rem;
}

nav a {
margin: 0 1rem;
text-decoration: none;
color: #fff;
font-weight: bold;
transition: 0.3s;
}

nav a:hover {
color: #ffcc00;
}

section {
width: 90%;
max-width: 1200px;
margin: 2rem auto;
background: rgba(0,0,0,0.6);
border-radius: 15px;
padding: 2rem;
}

.nails {
display: flex;
justify-content: space-around;
margin-bottom: 2rem;
}

.nail {
width: 80px;
height: 120px;
background: #000;
border-radius: 50px 50px 10px 10px;
box-shadow: 0 0 10px #333;
}

.bakery {
display: flex;
justify-content: space-around;
flex-wrap: wrap;
}

.cake {
width: 200px;
height: 150px;
background: linear-gradient(135deg, #ff1c1c, #0a0a7a);
border-radius: 15px;
margin: 1rem;
position: relative;
box-shadow: 0 0 10px #222;
}

.cake::before {
content: '';
position: absolute;
top: -20px;
left: 50%;
transform: translateX(-50%);
width: 40px;
height: 20px;
background: #fff;
border-radius: 50%;
}

footer {
width: 100%;
text-align: center;
padding: 1rem 0;
background: rgba(0,0,0,0.5);
margin-top: auto;
}

</style>
<!-- Pixel font -->
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
</head>
<body>
<header>
<h1>NENA</h1>
<nav>
<a href="#nails">Nails</a>
<a href="#bakery">Bakery</a>
<a href="#contact">Contact</a>
</nav>
</header>

<section id="nails">
<h2 style="text-align:center;">Nails</h2>
<div class="nails">
<div class="nail"></div>
<div class="nail"></div>
<div class="nail"></div>
<div class="nail"></div>
<div class="nail"></div>
</div>
</section>

<section id="bakery">
<h2 style="text-align:center;">Bakery</h2>
<div class="bakery">
<div class="cake"></div>
<div class="cake"></div>
<div class="cake"></div>
<div class="cake"></div>
</div>
</section>

<section id="contact">
<h2 style="text-align:center;">Contact</h2>
<p style="text-align:center;">Email:only.nena.coco@gmail.com</p>
<p style="text-align:center;">Phone: (202) 850-9579</p>
</section>

<footer>
&copy; 2026 Nena Nails & Bakery
</footer>
</body>
</html>
